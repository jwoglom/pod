# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build/*
# Keep the placeholder so the Go //go:embed in webui.go can compile even
# without a fresh `npm run build`. Build artifacts (asset-manifest.json,
# index.html, static/) remain ignored and get repopulated by `npm run build`.
!/build/.placeholder

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
